<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        :root {
            --primary: #6366f1;
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            --card-bg: #ffffff;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --success: #10b981;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            color: var(--text-main);
        }

        .container {
            width: 100%;
            max-width: 480px;
            padding: 2rem;
            box-sizing: border-box;
        }

        .card {
            background: var(--card-bg);
            padding: 3rem 2.5rem;
            border-radius: 1.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .icon {
            width: 80px;
            height: 80px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 1.5rem;
        }

        h2 {
            margin: 0 0 1rem;
            color: var(--primary);
        }

        p {
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .user-info {
            background: #f9fafb;
            padding: 1.5rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            text-align: left;
        }

        .user-info div {
            margin-bottom: 0.5rem;
        }

        .user-info strong {
            color: var(--text-main);
        }

        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .btn {
            padding: 0.875rem;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 0.5rem;
            font-weight: 600;
            transition: opacity 0.2s;
        }

        .btn:hover {
            opacity: 0.9;
        }

        .btn-secondary {
            background: #e5e7eb;
            color: var(--text-main);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="icon">✓</div>
            <h2>Success!</h2>
            <p>Welcome, <strong><%= user.name %></strong>! Your account has been created successfully.</p>
            
            <div class="user-info">
                <div><strong>Email:</strong> <%= user.email %></div>
                <div><strong>Age:</strong> <%= user.age %></div>
                <div><strong>ID:</strong> <%= user.id %></div>
            </div>

            <div class="btn-group">
                <a href="/data" class="btn">View All Submissions</a>
                <a href="/" class="btn btn-secondary">Go Back</a>
            </div>
        </div>
    </div>
</body>
</html>
